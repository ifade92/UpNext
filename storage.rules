rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Barber profile photos — public read (customer-facing surfaces show avatars
    // on queue.html, checkin.html, and the kiosk without authenticating users).
    // Authenticated write only — owner-facing UI already gates the upload control
    // to shop owners. Tighter ownership checks would require Firestore lookups
    // from Storage rules; defer that hardening unless explicitly requested.
    match /shops/{shopId}/barbers/{barberId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny — explicit catch-all for everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
