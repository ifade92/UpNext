rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────────────────
    //
    // userBelongsToShop(shopId)
    //   Returns true if the logged-in user's Firestore profile has a shopId
    //   that matches the shop being accessed. Prevents cross-shop access.
    //
    // isShopOwner(shopId)
    //   Returns true if the logged-in user is the OWNER of this shop.
    //   Used for admin-level operations like managing barbers, services, settings.
    //
    // isOwnBarberDoc(shopId, barberId)
    //   Returns true if the logged-in barber's barberId matches the doc being updated.
    //   Lets barbers update their own status/goLive without touching other barbers.
    //
    // isValidQueueCreate()
    //   Validates fields on a NEW queue entry from unauthenticated kiosk/web check-in.
    //   Ensures required fields exist and have sane types to prevent garbage data.

    function userBelongsToShop(shopId) {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == shopId;
    }

    function isShopOwner(shopId) {
      return request.auth != null
        && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
    }

    function isOwnBarberDoc(shopId, barberId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.barberId == barberId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == shopId;
    }

    function isValidQueueCreate() {
      let d = request.resource.data;
      // Phone is OPTIONAL while SMS/A2P isn't active. When A2P is approved and
      // the phone field is re-enabled in checkin.html, tighten this back to
      // require d.customerPhone.matches('^\\+[1-9][0-9]{6,14}$').
      return d.keys().hasAll(['customerName', 'customerPhone', 'status', 'checkInTime'])
        && d.customerName is string
        && d.customerName.size() > 0
        && d.customerName.size() <= 100
        && d.customerPhone is string
        && (d.customerPhone.size() == 0
            || d.customerPhone.matches('^\\+[1-9][0-9]{6,14}$'))  // empty OR valid E.164
        && d.status == 'waiting';                                   // New entries must start as waiting
    }

    // isCustomerSelfUpdate()
    //   Allows unauthenticated customers to make LIMITED updates to their own
    //   queue entry — specifically leaving the queue (status → "removed") or
    //   marking arrival for remote check-in (remoteStatus → "arrived").
    //   Only these two fields can be changed; everything else stays locked.
    function isCustomerSelfUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.size() == 1
        && (
          // Customer leaves the queue from the wait page
          (changed.hasOnly(['status']) && request.resource.data.status == 'removed')
          ||
          // Remote check-in customer marks themselves as arrived
          (changed.hasOnly(['remoteStatus']) && request.resource.data.remoteStatus == 'arrived')
        );
    }


    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can only read and write their own document.
    // Created during signup, read on app launch to get role + shopId.
    // No deletes — deactivation is handled by removing shop association.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }


    // ── Customers ────────────────────────────────────────────────────────────
    // Customer records (keyed by phone number) are created/updated during
    // check-in by the kiosk (unauthenticated), and by barbers when completing
    // a service (incrementing visit count).
    //
    // Read: open (kiosk needs to look up returning customers)
    // Create: open (kiosk creates new customer records on first check-in)
    // Update: authenticated users only (barbers increment visitCount, update preferences)
    // Delete: not allowed (customer data retained for returning customer features)
    match /customers/{phoneNumber} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null;
      allow delete: if false;
    }


    // ── Shops ────────────────────────────────────────────────────────────────
    // Read: open (kiosk, TV screen, and web check-in need unauthenticated access)
    // Create: any authenticated user (owner signup flow)
    //         — ownerId must match the creating user's auth UID
    // Update: owner ONLY (name, hours, settings, subscription status)
    // Delete: owner ONLY (and honestly, don't do this — contact support)
    match /shops/{shopId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isShopOwner(shopId);
      allow delete: if isShopOwner(shopId);


      // ── Active Queue ───────────────────────────────────────────────────────
      // Read: open (TV queue display and kiosk confirmation need unauthenticated access)
      // Create: anyone IF data passes validation (kiosk check-in from iPad or web)
      //         — requires valid customerName, E.164 phone, and status = "waiting"
      // Update: shop members can change anything (barbers manage queue flow);
      //         unauthenticated customers can ONLY mark themselves removed or arrived
      // Delete: any shop member — barbers need this to archive completed/removed
      //         entries (archiveEntry writes to queueHistory then deletes the active doc)
      match /queue/{entryId} {
        allow read: if true;
        allow create: if isValidQueueCreate();
        allow update: if userBelongsToShop(shopId) || isCustomerSelfUpdate();
        allow delete: if userBelongsToShop(shopId);
      }


      // ── Queue History ──────────────────────────────────────────────────────
      // Read: open (TV queue page can show today's completed count)
      // Create: shop members (archive completed entries from active queue)
      // Update: shop members — archiveEntry uses setDoc which is treated as an
      //         update when a history doc with the same ID already exists (e.g.
      //         auto-complete already archived it once). Barbers need this to
      //         re-archive with a corrected status.
      // Delete: owner only (corrections, cleanup)
      match /queueHistory/{entryId} {
        allow read: if true;
        allow create, update: if userBelongsToShop(shopId);
        allow delete: if isShopOwner(shopId);
      }


      // ── Barbers ───────────────────────────────────────────────────────────
      // Read: open (kiosk shows barber grid for customer selection)
      // Create: owner only (adding new barbers to the team)
      // Update: owner can update any barber;
      //         barbers can update ONLY their own doc (status, goLive, currentClientId)
      // Delete: owner only (removing barbers from the team)
      match /barbers/{barberId} {
        allow read: if true;
        allow create: if isShopOwner(shopId);
        allow update: if isShopOwner(shopId) || isOwnBarberDoc(shopId, barberId);
        allow delete: if isShopOwner(shopId);
      }


      // ── Services ──────────────────────────────────────────────────────────
      // Read: open (kiosk shows service menu for customer selection)
      // Write: owner only (manage service menu — add, edit, deactivate)
      match /services/{serviceId} {
        allow read: if true;
        allow write: if isShopOwner(shopId);
      }


      // ── Settings ──────────────────────────────────────────────────────────
      // Read: open (kiosk needs display settings like queueDisplayMode)
      // Write: owner only (SMS templates, auto-close time, display preferences)
      match /settings/{docId} {
        allow read: if true;
        allow write: if isShopOwner(shopId);
      }
    }


    // ── Everything else ───────────────────────────────────────────────────────
    // Deny access to any collection not explicitly covered above.
    // This is Firestore's default, but being explicit catches mistyped paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
